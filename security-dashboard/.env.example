# ── Wyze credentials ────────────────────────────────────────────────────────
# Your Wyze account email and password
WYZE_EMAIL=you@example.com
WYZE_PASSWORD=your-wyze-password

# Wyze API key (get from: https://developer-api-console.wyze.com)
# Click "API Keys" → "Add Key" → copy both values below
WYZE_API_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
WYZE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The local IP of the Mac running Docker (run: ipconfig getifaddr en0)
HOST_IP=192.168.1.100

# ── D-Link camera RTSP URLs ──────────────────────────────────────────────────
# Format: rtsp://admin:PASSWORD@CAMERA-IP:554/live/ch00_0
# Common D-Link URL patterns (try in order if one doesn't work):
#   rtsp://admin:pass@192.168.1.x:554/live/ch00_0        (most DCS models)
#   rtsp://admin:pass@192.168.1.x:554/play1.sdp          (older models)
#   rtsp://admin:pass@192.168.1.x:554/live1.sdp          (some models)
DLINK_CAM1_RTSP=rtsp://admin:password@192.168.1.101:554/live/ch00_0
DLINK_CAM2_RTSP=rtsp://admin:password@192.168.1.102:554/live/ch00_0

# Add DLINK_CAM3_RTSP, DLINK_CAM4_RTSP, etc. as needed
